PORT=3000

# TAVSİYE EDİLEN — SendGrid (100k+ kullanıcıya ölçeklenir)
# 1. https://sendgrid.com → Free signup (100 email/gün ücretsiz)
# 2. Settings → API Keys → Create API Key (Full Access)
# 3. Settings → Sender Authentication → Single Sender Verification (kendi mailini doğrula)
SENDGRID_API_KEY=SG.xxxxx
FROM_EMAIL=ornek@ornek.com

# YEDEK — Gmail SMTP (küçük testler için, günlük 500 limit)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=ornek@gmail.com
# SMTP_PASS=16haneli-uygulama-sifresi
